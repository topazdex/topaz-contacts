# Deployment Configuration
PRIVATE_KEY_DEPLOY=0x...

# BNB Chain RPC URLs (optional - defaults to public RPCs)
BSC_TESTNET_RPC_URL=
BSC_MAINNET_RPC_URL=

# BscScan API Key (single key works for both testnet and mainnet)
BSCSCAN_API_KEY=

# Named Accounts (optional - will use deployer if not set)
TEAM_ADDRESS=
FEE_MANAGER_ADDRESS=
EMERGENCY_COUNCIL_ADDRESS=
ALLOWED_MANAGER_ADDRESS=

# Gas Reporting
REPORT_GAS=false
