{
  "name": "topaz",
  "version": "2.0.0",
  "description": "Solidly-style ve(3,3) AMM for BNB Chain",
  "license": "MIT",
  "directories": {
    "lib": "lib"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^1.0.6",
    "@nomicfoundation/hardhat-ethers": "^3.0.9",
    "@nomicfoundation/hardhat-foundry": "^1.0.1",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.8",
    "@nomicfoundation/hardhat-toolbox": "^2.0.2",
    "@nomicfoundation/hardhat-verify": "^2.0.8",
    "@nomiclabs/hardhat-etherscan": "^3.1.7",
    "@openzeppelin/contracts": "4.8.0",
    "@tenderly/hardhat-tenderly": "1.7.5",
    "@typechain/ethers-v6": "^0.5.0",
    "@typechain/hardhat": "^9.0.0",
    "@types/chai": "^4.3.5",
    "@types/mocha": "^10.0.1",
    "chai": "^4.3.7",
    "decimal.js": "^10.4.3",
    "dotenv": "^16.0.3",
    "ethers": "^6.10.0",
    "fs": "^0.0.1-security",
    "hardhat": "^2.13.1",
    "hardhat-deploy": "^0.12.1",
    "hardhat-gas-reporter": "^1.0.9",
    "prettier": "^2.6.2",
    "prettier-plugin-solidity": "^1.0.0-beta.19",
    "solhint": "^3.3.7",
    "solhint-plugin-prettier": "^0.0.5",
    "solidity-coverage": "^0.8.2",
    "ts-node": "^10.9.1",
    "typechain": "^8.2.0",
    "typescript": "^5.1.3"
  },
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy:testnet": "hardhat deploy --network bscTestnet",
    "deploy:mainnet": "hardhat deploy --network bscMainnet",
    "verify:testnet": "hardhat verify --network bscTestnet",
    "verify:mainnet": "hardhat verify --network bscMainnet",
    "format": "prettier --write 'contracts/**/*.sol' 'deploy/**/*.ts' 'hardhat.config.ts'",
    "format:check": "prettier --check 'contracts/**/*.sol' 'deploy/**/*.ts' 'hardhat.config.ts'",
    "lint": "solhint --fix 'contracts/**/*.sol'",
    "lint:check": "solhint 'contracts/**/*.sol'",
    "clean": "hardhat clean"
  }
}
